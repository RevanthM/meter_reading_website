{
  "name": "meter_reading_website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "vite",
    "dev:fresh": "sh -c 'lsof -ti tcp:5173 | xargs kill -9 2>/dev/null || true; vite'",
    "server": "node server/index.js",
    "check-bucket": "node server/check-bucket.js",
    "dev:all": "concurrently --names server,vite -c blue,green \"npm run server\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "deploy:eb": "npm run build && eb deploy",
    "lint": "eslint .",
    "preview": "vite preview",
    "manual:screenshots": "node scripts/capture-user-manual-screenshots.mjs",
    "manual:pdf": "node scripts/build-user-manual-pdf.mjs",
    "migrate:unit-test-manifest": "node scripts/migrate-unit-test-manifest-to-json.mjs",
    "backfill:iteration-csv-metrics": "node scripts/backfill-iteration-metrics-from-unit-test-csv.mjs",
    "backfill:dynamo-sessions": "node scripts/backfill-dynamo-sessions.mjs",
    "reclassify:field-sessions": "node scripts/reclassify-field-sessions.mjs --dry-run",
    "reclassify:field-sessions:execute": "node scripts/reclassify-field-sessions.mjs --execute",
    "reclassify:field-sessions:bulk": "python3 scripts/reclassify_field_sessions_bulk.py --dry-run",
    "reclassify:field-sessions:bulk:execute": "python3 scripts/reclassify_field_sessions_bulk.py --execute --workers 32",
    "relabel:capture-locations": "python3 scripts/relabel_capture_locations.py --dry-run",
    "relabel:capture-locations:execute": "python3 scripts/relabel_capture_locations.py --execute",
    "sync:lambda-session-index": "sh scripts/sync-lambda-session-index.sh",
    "deploy:session-index": "npm run sync:lambda-session-index && cd infra/session-sync && sam build && sam deploy --stack-name amr-session-index --resolve-s3 --capabilities CAPABILITY_IAM --region us-east-1 --parameter-overrides SessionsTableName=amr-sessions S3BucketName=meter-reader-training-feedback --no-confirm-changeset --no-fail-on-empty-changeset"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.966.0",
    "@aws-sdk/client-s3": "^3.966.0",
    "@aws-sdk/s3-request-presigner": "^3.966.0",
    "@aws-sdk/util-dynamodb": "^3.966.0",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "fflate": "^0.8.3",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.562.0",
    "multer": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.15.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.49.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
