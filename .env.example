# AWS S3 — for local testing, put real values in either:
#   - `/.env` at the repo root, or
#   - `/src/.env` (also gitignored; loaded after root so it can override).
# Never put real keys in `.env.example`.
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
# AMR prod / S3 bucket is typically us-west-2 — match region to your bucket when using Dynamo:
# AWS_REGION=us-west-2
# DynamoDB session index (after SAM deploy in infra/session-sync):
# AWS_DYNAMODB_SESSIONS_TABLE=amr-sessions
# In-memory API cache (default: stale-while-revalidate — fast + fresh enough)
# API_CACHE_FRESH_MS=8000
# API_CACHE_STALE_MAX_MS=45000
# UNIT_TEST_RUNS_CACHE_TTL_MS=30000
# UNIT_TEST_RUNS_STALE_MAX_MS=120000
# UNIT_TEST_SUMMARY_DEFAULT_LIMIT=50
# DYNAMO_LIST_PRESIGN_CONCURRENCY=40
# Use the AWS profile for the AMR account (not a personal/Beanstalk account):
# export AWS_PROFILE=your-amr-profile
# Optional; default matches training-feedback bucket
# AWS_S3_BUCKET=meter-reader-training-feedback
# Improvement chart index (default: same bucket, key analytics/improvement/…/index.json)
# AWS_ANALYTICS_S3_KEY_PREFIX=analytics
# Only if you use a separate bucket with IAM on that bucket (otherwise leave unset):
# AWS_ANALYTICS_S3_BUCKET=meter-reader-analytics
# If uploads live under a parent prefix (e.g. prod/ or env/staging/), counts/readings scan that tree:
# AWS_S3_BASE_PREFIX=prod
# Portal “training dataset” folders are created under this segment in the same bucket (default: training-datasets):
# AWS_S3_TRAINING_DATASETS_ROOT=training-datasets
# Max sessions per POST /api/training-datasets/copy-sessions (default 80)
# COPY_TO_TRAINING_MAX_SESSIONS=80
# Max S3 objects per GET /api/export/training-dataset-zip (default 8000)
# TRAINING_DATASET_EXPORT_MAX_OBJECTS=8000

# Firebase (optional — email/phone MFA & MFA Settings; omit when using user ID sign-in only)
# Firebase Configuration (for Vite frontend - must be prefixed with VITE_)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Auth API base URL (defaults to bundled backend if unset)
VITE_ANICA_LOGIN_AUTH_BASE_URL=https://chatanicaappep2.azurewebsites.net
# Dev only: proxy path in Vite to avoid browser CORS (see vite.config.ts)
# VITE_ANICA_LOGIN_AUTH_USE_PROXY=true

# SendOTP / ValidateOTP query values (defaults: AMR)
# VITE_ANICA_LOGIN_APPL=AMR
# VITE_ANICA_LOGIN_ROLE=AMR
# VITE_ANICA_LOGIN_APP_OTP=AMR

# POST /Register default Role in JSON body
# VITE_ANICA_LOGIN_REGISTER_ROLE=AMR

# Microsoft SSO (UI placeholder for now; wire this when Entra integration ships)
# VITE_AD_SSO_URL=https://login.microsoftonline.com/<tenant>/oauth2/v2.0/authorize?...

# Cap for incorrect-retrain ZIP (server); default 3000 sessions per download
# EXPORT_INCORRECT_MAX_SESSIONS=3000

# Portal "Upload & run model" — DISABLED (required local Python + YOLO on the API host).
# See server/meterInference.js and server/portalInferenceUpload.js if re-enabling.

# Roboflow (Node server only — never prefix with VITE_; used by server/roboflow.js for /api/roboflow/*)
# Put the key in src/.env (gitignored) or repo root .env — server loads both (src/.env wins on duplicate keys).
# Private API key: https://app.roboflow.com/account/api
# ROBOFLOW_API_KEY=your_private_api_key
# Optional if your key resolves a single workspace from GET https://api.roboflow.com/?api_key=
# ROBOFLOW_WORKSPACE=my-workspace
